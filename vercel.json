{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/analysis.js": {
      "maxDuration": 60
    },
    "api/ai.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "0 22 * * 1-5"
    },
    {
      "path": "/api/cron/weekly",
      "schedule": "0 11 * * 0"
    }
  ]
}