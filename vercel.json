{
  "functions": {
    "api/ml-trainer.js": {
      "maxDuration": 60
    },
    "api/chart-analysis.js": {
      "maxDuration": 30
    },
    "api/predict.js": {
      "maxDuration": 60
    },
    "api/analysis.js": {
      "maxDuration": 30
    },
    "api/eod-debrief.js": {
      "maxDuration": 60
    },
    "api/journal-ai.js": {
      "maxDuration": 30
    },
    "api/options-recommend.js": {
      "maxDuration": 30
    },
    "api/cron/weekly-report.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/weekly-report?admin=true",
      "schedule": "0 23 * * 0"
    }
  ]
}