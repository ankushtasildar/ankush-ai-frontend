{
  "functions": {
    "api/ml-trainer.js": {
      "maxDuration": 60
    },
    "api/chart-analysis.js": {
      "maxDuration": 30
    },
    "api/predict.js": {
      "maxDuration": 60
    },
    "api/analysis.js": {
      "maxDuration": 30
    },
    "api/eod-debrief.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}